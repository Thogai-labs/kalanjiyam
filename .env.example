# Copy to .env and fill in real values. Never commit .env.

# Flask / app
FLASK_ENV=development
SECRET_KEY=change-me
SQLALCHEMY_DATABASE_URI=sqlite:///database.db
FLASK_UPLOAD_FOLDER=/absolute/path/to/data/file-uploads

# URL prefix — set to /kalanjiyam when hosting at siddhasagaram.in/kalanjiyam
# Leave empty for root hosting (http://localhost:5000/)
APPLICATION_URL_PREFIX=

# Remote OCR service (required when OCR_BACKEND=remote)
OCR_BACKEND=remote
OCR_SERVICE_URL=http://localhost:5001
OCR_SERVICE_API_KEY=
OCR_SERVICE_TIMEOUT=300

# Background tasks
REDIS_URL=redis://localhost:6379/0
KALANJIYAM_BOT_PASSWORD=change-me

# Production only
SENTRY_DSN=

# Multi-tenant / organizations (see docs/multi-tenant.rst)
MULTI_TENANT_MODE=false
ENFORCE_ORG_ACCESS=true
DEFAULT_PROJECT_REQUIRES_ORG=true
# Legacy group gates (optional; can combine with org mode)
ENFORCE_GROUP_ACCESS_FOR_PROJECTS=false
ENFORCE_GROUP_ACCESS_FOR_TEXTS=false
MAIL_SERVER=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# Docker production (deploy/prod)
# POSTGRES_PASSWORD=
# OCR_SERVICE_URL=http://your-ocr-host:5001
